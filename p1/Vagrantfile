# -*- mode: ruby -*-
# vi: set ft=ruby :

K3S_TOKEN = "4242TokenIOTicham"
SERVER_IP  = "192.168.56.110"
WORKER_IP  = "192.168.56.111"

Vagrant.configure("2") do |config|
  config.vm.box = "generic/debian12"
  config.vm.box_check_update = false

  # Synced folder via rsync (libvirt ne supporte pas VirtualBox shared folders)
  config.vm.synced_folder ".", "/vagrant", type: "rsync",
    rsync__exclude: [".git/", ".vagrant/"]

  config.vm.define "ijaberS", primary: true do |server|
    server.vm.hostname = "ijaberS"
    server.vm.network "private_network", ip: SERVER_IP

    server.vm.provider :libvirt do |lv|
      lv.driver        = "kvm"
      lv.cpus          = 1
      lv.memory        = 1024
      lv.linked_clone  = true
    end

    server.vm.provision "shell", path: "scripts/script.sh",
      args: ["server", SERVER_IP, K3S_TOKEN]
  end

  config.vm.define "ijaberSW" do |worker|
    worker.vm.hostname = "ijaberSW"
    worker.vm.network "private_network", ip: WORKER_IP

    worker.vm.provider :libvirt do |lv|
      lv.driver        = "kvm"
      lv.cpus          = 1
      lv.memory        = 1024
      lv.linked_clone  = true
    end

    worker.vm.provision "shell", path: "scripts/script.sh",
      args: ["agent", SERVER_IP, K3S_TOKEN]
  end
end