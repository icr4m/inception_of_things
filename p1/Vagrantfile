Vagrant.configure("2") do |config|
  config.vm.box = "debian/bookworm64"

  config.vm.define "ijaberS" do |s|
    s.vm.hostname = "ijaberS"
    s.vm.network "private_network", ip: "192.168.56.110"
    s.vm.provider "virtualbox" do |v|
      v.name = "ijaberS"
      v.cpus = 1
      v.memory = 2048
    end
    s.vm.provision "shell", path: "scripts/script.sh", args: ["server", "192.168.56.110"]
  end

  config.vm.define "ijaberSW" do |w|
    w.vm.hostname = "ijaberSW"
    w.vm.network "private_network", ip: "192.168.56.111"
    w.vm.provider "virtualbox" do |v|
      v.name = "ijaberSW"
      v.cpus = 1
      v.memory = 2048
    end
    w.vm.provision "shell", path: "scripts/script.sh", args: ["agent", "192.168.56.110"]
  end
end%
