Vagrant.configure("2") do |config|
  config.vm.box = "debian/trixie64"

  config.vm.define "ijaberS" do |s|
    s.vm.hostname = "ijaberS"
    s.vm.network "private_network", ip: "192.168.56.110"
    s.vm.provider "libvirt" do |v|
      v.cpus = 1
      v.memory = 2048
    end
    s.vm.provision "shell", path: "scripts/script.sh", args: ["server", "192.168.56.110"]
  end

  config.vm.define "ijaberSW" do |w|
    w.vm.hostname = "ijaberSW"
    w.vm.network "private_network", ip: "192.168.56.111"
    w.vm.provider "libvirt" do |v|
      v.cpus = 1
      v.memory = 2048
    end
    w.vm.provision "shell", 
    path: "scripts/script.sh", 
    args: ["agent", "192.168.56.110", "192.168.56.111"]
  end

  # --- AJOUT DES TRIGGERS DE NETTOYAGE ---
  config.trigger.after :destroy do |trigger|
    trigger.run = {inline: "rm -f node-token"}
  end

  config.trigger.before :up do |trigger|
    trigger.run = {inline: "rm -f node-token"}
  end
end
